# Copy to .env before running `docker compose up`.

# Runtime
ENV=development
LOG_LEVEL=info
PUBLIC_CONTROL_PLANE_URL=http://localhost:8080
# Graceful shutdown window in seconds. Must be less than the container platform's
# termination grace period (Cloud Run default: 10s; set --termination-grace-period-seconds
# to match or exceed this value for zero-downtime deploys).
SHUTDOWN_TIMEOUT_SECONDS=10
# Max Postgres connections per service instance. With Cloud Run autoscaling, total
# connections = DB_MAX_CONNS × max-instances. Keep below Cloud SQL max_connections.
DB_MAX_CONNS=4
DB_MIN_CONNS=1
DB_HEALTH_CHECK_PERIOD_SECONDS=30

# Security
# Comma-separated list of allowed CORS origins. Defaults to * in development.
# In production, set to your actual frontend origin(s).
CORS_ALLOWED_ORIGINS=*
# Global rate limit: max requests per minute per IP address.
RATE_LIMIT_RPM=120
# LLM endpoint rate limit: max requests per minute per IP for query/semantic/starter routes.
RATE_LIMIT_LLM_RPM=30
# Maximum request body size in bytes (default 1MB).
MAX_REQUEST_BODY_BYTES=1048576

# Postgres (local docker-compose)
POSTGRES_DB=mission
POSTGRES_USER=mission
POSTGRES_PASSWORD=mission
POSTGRES_PORT=5432

# Host ports
BACKEND_PORT=8080
FRONTEND_PORT=5173
MYSQL_PORT=3306

# LLM providers (at least one required for semantic layer and query generation)
# Supported providers: anthropic, openai, together, mistral, cerebras, deepseek, xai, fireworks
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
TOGETHER_API_KEY=
MISTRAL_API_KEY=
CEREBRAS_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
FIREWORKS_API_KEY=
DEFAULT_LLM_PROVIDER=anthropic
SEMANTIC_LAYER_MODEL=claude-sonnet-4-6
QUERY_MODEL=claude-sonnet-4-6
# For DeepSeek structured query + semantic-layer flows, prefer `deepseek-chat`.
ANTHROPIC_SEMANTIC_LAYER_MODEL=
OPENAI_SEMANTIC_LAYER_MODEL=
TOGETHER_SEMANTIC_LAYER_MODEL=
MISTRAL_SEMANTIC_LAYER_MODEL=
CEREBRAS_SEMANTIC_LAYER_MODEL=
DEEPSEEK_SEMANTIC_LAYER_MODEL=
XAI_SEMANTIC_LAYER_MODEL=
FIREWORKS_SEMANTIC_LAYER_MODEL=
ANTHROPIC_QUERY_MODEL=
OPENAI_QUERY_MODEL=
TOGETHER_QUERY_MODEL=
MISTRAL_QUERY_MODEL=
CEREBRAS_QUERY_MODEL=
DEEPSEEK_QUERY_MODEL=
XAI_QUERY_MODEL=
FIREWORKS_QUERY_MODEL=
# Optional live-check models used by scripts/preflight*.sh.
ANTHROPIC_PREFLIGHT_MODEL=claude-3-5-haiku-latest
OPENAI_PREFLIGHT_MODEL=gpt-4.1-nano
TOGETHER_PREFLIGHT_MODEL=
MISTRAL_PREFLIGHT_MODEL=
CEREBRAS_PREFLIGHT_MODEL=
DEEPSEEK_PREFLIGHT_MODEL=deepseek-chat
XAI_PREFLIGHT_MODEL=
FIREWORKS_PREFLIGHT_MODEL=

# Image reference shown to tenants during onboarding/install flows.
EDGE_AGENT_VERSION=v0.1.0
EDGE_AGENT_IMAGE_REPOSITORY=registry.digitalocean.com/mission/edge-agent
# Legacy override. Leave empty unless you need to point onboarding at a full custom image ref.
EDGE_AGENT_IMAGE=

# Clerk
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
# Same Clerk publishable key, exposed to the browser through /app-config.json.
VITE_CLERK_PUBLISHABLE_KEY=

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
# Optional frontend-specific Sentry values exposed through /app-config.json.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_RELEASE=

# Edge agent (used by `go run ./cmd/edge-agent`)
CONTROL_PLANE_URL=http://localhost:8080
TENANT_TOKEN=
AGENT_VERSION=dev
HEARTBEAT_INTERVAL_SECONDS=10
RECONNECT_BASE_SECONDS=1
RECONNECT_MAX_SECONDS=30
MYSQL_DSN_FILE=/etc/agent/mysql.dsn
AGENT_AUDIT_LOG_PATH=/var/lib/agent/audit/query-events.jsonl
# Alternative to MYSQL_DSN_FILE for local dev (takes precedence when set).
# MYSQL_DSN=root:mission@tcp(127.0.0.1:3306)/mission_app

# MySQL integration tests default to the docker-compose users below. Override
# these if you want `go test ./...` to target a different MySQL instance.
# MISSION_TEST_MYSQL_READONLY_DSN=mission_ro:mission_ro@tcp(127.0.0.1:3306)/mission_app
# MISSION_TEST_MYSQL_READWRITE_DSN=mission_rw:mission_rw@tcp(127.0.0.1:3306)/mission_app

# Set by docker-compose for the container; uncomment for host-side tools.
DATABASE_URL=postgres://mission:mission@localhost:5432/mission?sslmode=disable
