# Copy to .env before running `docker compose up`.

# Runtime
ENV=development
LOG_LEVEL=info

# Postgres (local docker-compose)
POSTGRES_DB=mission
POSTGRES_USER=mission
POSTGRES_PASSWORD=mission
POSTGRES_PORT=5432

# Host ports
BACKEND_PORT=8080
FRONTEND_PORT=5173
MYSQL_PORT=3306

# LLM providers (at least one required once LLM gateway is wired in 1.2+)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEFAULT_LLM_PROVIDER=anthropic
SEMANTIC_LAYER_MODEL=claude-sonnet-4-6

# Clerk (wired in 1.2)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
# Same Clerk publishable key, exposed to the Vite client bundle.
VITE_CLERK_PUBLISHABLE_KEY=

# Edge agent (used by `go run ./cmd/edge-agent`)
CONTROL_PLANE_URL=http://localhost:8080
TENANT_TOKEN=
AGENT_VERSION=dev
HEARTBEAT_INTERVAL_SECONDS=10
RECONNECT_BASE_SECONDS=1
RECONNECT_MAX_SECONDS=30
MYSQL_DSN_FILE=/etc/mission/mysql.dsn
# Alternative to MYSQL_DSN_FILE for local dev (takes precedence when set).
# MYSQL_DSN=root:mission@tcp(127.0.0.1:3306)/mission_app

# MySQL integration tests default to the docker-compose users below. Override
# these if you want `go test ./...` to target a different MySQL instance.
# MISSION_TEST_MYSQL_READONLY_DSN=mission_ro:mission_ro@tcp(127.0.0.1:3306)/mission_app
# MISSION_TEST_MYSQL_READWRITE_DSN=mission_rw:mission_rw@tcp(127.0.0.1:3306)/mission_app

# Set by docker-compose for the container; uncomment for host-side tools.
DATABASE_URL=postgres://mission:mission@localhost:5432/mission?sslmode=disable
