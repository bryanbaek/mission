# Copy to .env before running `docker compose up`.

# Runtime
ENV=development
LOG_LEVEL=info
PUBLIC_CONTROL_PLANE_URL=http://localhost:8080

# Postgres (local docker-compose)
POSTGRES_DB=mission
POSTGRES_USER=mission
POSTGRES_PASSWORD=mission
POSTGRES_PORT=5432

# Host ports
BACKEND_PORT=8080
FRONTEND_PORT=5173
MYSQL_PORT=3306

# LLM providers (at least one required for semantic layer and query generation)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEFAULT_LLM_PROVIDER=anthropic
SEMANTIC_LAYER_MODEL=claude-sonnet-4-6
QUERY_MODEL=claude-sonnet-4-6
ANTHROPIC_PREFLIGHT_MODEL=claude-3-5-haiku-latest
OPENAI_PREFLIGHT_MODEL=gpt-4.1-nano

# Image reference shown to tenants during onboarding/install flows.
EDGE_AGENT_VERSION=v0.1.0
EDGE_AGENT_IMAGE_REPOSITORY=registry.digitalocean.com/mission/edge-agent
# Legacy override. Leave empty unless you need to point onboarding at a full custom image ref.
EDGE_AGENT_IMAGE=

# Clerk
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
# Same Clerk publishable key, exposed to the Vite client bundle.
VITE_CLERK_PUBLISHABLE_KEY=

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_RELEASE=

# Edge agent (used by `go run ./cmd/edge-agent`)
CONTROL_PLANE_URL=http://localhost:8080
TENANT_TOKEN=
AGENT_VERSION=dev
HEARTBEAT_INTERVAL_SECONDS=10
RECONNECT_BASE_SECONDS=1
RECONNECT_MAX_SECONDS=30
MYSQL_DSN_FILE=/etc/agent/mysql.dsn
AGENT_AUDIT_LOG_PATH=/var/lib/agent/audit/query-events.jsonl
# Alternative to MYSQL_DSN_FILE for local dev (takes precedence when set).
# MYSQL_DSN=root:mission@tcp(127.0.0.1:3306)/mission_app

# MySQL integration tests default to the docker-compose users below. Override
# these if you want `go test ./...` to target a different MySQL instance.
# MISSION_TEST_MYSQL_READONLY_DSN=mission_ro:mission_ro@tcp(127.0.0.1:3306)/mission_app
# MISSION_TEST_MYSQL_READWRITE_DSN=mission_rw:mission_rw@tcp(127.0.0.1:3306)/mission_app

# Set by docker-compose for the container; uncomment for host-side tools.
DATABASE_URL=postgres://mission:mission@localhost:5432/mission?sslmode=disable
